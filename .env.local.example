# Mapbox API Key (hämta från https://www.mapbox.com/)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Google Places API Key (hämta från https://console.cloud.google.com/)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_api_key_here

# Football API Key (använd API-Football från https://www.api-football.com/)
NEXT_PUBLIC_FOOTBALL_API_KEY=your_football_api_key_here
