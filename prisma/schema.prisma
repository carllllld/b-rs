generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  reports   Report[]
  comments  Comment[]
}

model Report {
  id              String   @id @default(cuid())
  barId           String
  barName         String
  showingMatch    Boolean
  matchName       String?
  withSound       Boolean
  crowdLevel      String?
  beerPrice       Int?
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  barId     String
  text      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
